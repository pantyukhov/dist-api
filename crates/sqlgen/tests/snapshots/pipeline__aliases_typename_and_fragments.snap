---
source: crates/sqlgen/tests/pipeline.rs
assertion_line: 150
expression: "plan_sql(r#\"query {\n            __typename\n            writers: author {\n                __typename\n                ident: id\n                ...AuthorBits\n            }\n        }\n        fragment AuthorBits on author { name }\"#)"
---
SELECT json_build_object('__typename', 'query_root'::text, 'writers', (SELECT coalesce(json_agg("_t1".j), '[]'::json) FROM (SELECT json_build_object('__typename', 'author'::text, 'ident', "_t0"."id", 'name', "_t0"."name") AS j FROM "public"."author" AS "_t0" WHERE "_t0"."id" = ('1')::"int4") AS "_t1")) AS root
