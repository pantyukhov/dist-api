---
source: crates/sqlgen/tests/pipeline.rs
assertion_line: 182
expression: "plan_sql(r#\"query {\n            article(where: { author: { name: { _eq: \"tolstoy\" } } }) { id }\n        }\"#)"
---
SELECT json_build_object('article', (SELECT coalesce(json_agg("_t2".j), '[]'::json) FROM (SELECT json_build_object('id', "_t0"."id") AS j FROM "public"."article" AS "_t0" WHERE (EXISTS (SELECT 1 FROM "public"."author" AS "_t1" WHERE "_t1"."id" = "_t0"."author_id" AND ("_t1"."name" = ('tolstoy')::"text" AND "_t1"."id" = ('1')::"int4")) AND ("_t0"."published" = TRUE OR "_t0"."author_id" = ('1')::"int4")) LIMIT 100) AS "_t2")) AS root
