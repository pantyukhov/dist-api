---
source: crates/sqlgen/tests/pipeline.rs
assertion_line: 116
expression: "plan_sql(r#\"query {\n            article(where: { published: { _eq: true } },\n                    order_by: { id: desc }, limit: 5, offset: 2) {\n                id\n                title\n            }\n        }\"#)"
---
SELECT json_build_object('article', (SELECT coalesce(json_agg("_t1".j), '[]'::json) FROM (SELECT json_build_object('id', "_t0"."id", 'title', "_t0"."title") AS j FROM "public"."article" AS "_t0" WHERE ("_t0"."published" = TRUE AND ("_t0"."published" = TRUE OR "_t0"."author_id" = ('1')::"int4")) ORDER BY "_t0"."id" DESC NULLS FIRST LIMIT 5 OFFSET 2) AS "_t1")) AS root
